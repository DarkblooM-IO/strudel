// "arp stuff" @by ÐarkbloøM

const vol = slider(0.06,.01,1,.01)

// arp
$: n("0 5 6 7").chord("<D^7 F#-9 C#- A>")
.voicing().s("supersaw").fast(2).gain(vol)
._pianoroll()
// chords
$: chord("D^7 F#-9 C#- A")
.voicing().s("supersaw").slow(4).lpf(800).gain(vol)

// kick
$: s("bd:1*4").duck(4).duckdepth(.7).gain(vol)
